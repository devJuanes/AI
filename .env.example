# Copia a .env y ajusta valores

# MatuDB — https://db.matudb.com (proyecto dedicado Matu AI)
MATUDB_URL=https://db.matudb.com
MATUDB_PROJECT_ID=tu-project-id-matu-ai
MATUDB_API_KEY=mb_tu_api_key_anon
MATUDB_SERVICE_KEY=mb_tu_service_key

# JWT del dashboard Matu AI
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Ollama — chat web usa modelos Cloud (ollama signin en el servidor)
# Ver: bash deploy/setup-cloud-models.sh
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_MS=300000
# Modelo chat web: liviano (~1.3 GB RAM)
DEFAULT_CHAT_MODEL=matu-nano
# Zona horaria para que Matu AI sepa la fecha/hora actual (chat web)
APP_TIMEZONE=America/Bogota

# Frontend — chat.matubyte.com | API — ai.matubyte.com
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173,https://chat.matubyte.com

# Frontend — build Vite (mismo origen que la API en producción)
#VITE_API_URL=http://localhost:3001
#VITE_DEFAULT_MODEL=qwen3.5:cloud

# Facturación API (recarga prepago)
BILLING_MIN_RECHARGE_USD=5
BILLING_TOKENS_PER_USD=200000
BILLING_USD_COP_RATE=4200
# true = acreditar sin Bold; false = pasarela real (requiere PayMatuByte encendido)
BILLING_MOCK_CHECKOUT=false

# PayMatuByte (pasarela Bold)
# Local:
PAYMATUBYTE_URL=http://localhost:3000
# Producción (VPS):
# PAYMATUBYTE_URL=https://pay.matubyte.com
PAYMATUBYTE_API_KEY=pk_matu_ai_local_dev_cambiar
PAYMATUBYTE_APP_ID=matu-ai

# Producción:
# CORS_ORIGIN=https://chat.matubyte.com
# VITE_API_URL=https://ai.matubyte.com

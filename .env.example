# Copia a .env y ajusta valores

# MatuDB — https://db.matudb.com (proyecto dedicado Matu AI)
MATUDB_URL=https://db.matudb.com
MATUDB_PROJECT_ID=tu-project-id-matu-ai
MATUDB_API_KEY=mb_tu_api_key_anon
MATUDB_SERVICE_KEY=mb_tu_service_key

# JWT del dashboard Matu AI
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_MS=300000

# API Matu AI — subdominio api.matubyte.com
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173,https://chat.matubyte.com

# Frontend — subdominio chat.matubyte.com (build Vite)
VITE_API_URL=http://localhost:3001

# Producción:
# CORS_ORIGIN=https://chat.matubyte.com
# VITE_API_URL=https://api.matubyte.com
